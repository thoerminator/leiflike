# Vorlage — auf dem Server nach ".env" kopieren und ausfüllen.
# Die echte .env gehört NICHT ins Repo (steht in .gitignore).

# Dein Admin-Passwort. Frei wählbar, gerne lang.
ADMIN_PASSWORD=bitte-hier-ein-eigenes-passwort

# Signiert die Anmelde-Cookies. Einmalig erzeugen mit:
#   openssl rand -base64 32
AUTH_SECRET=

# Wo Inhalte und Uploads liegen. In Docker ist das das Volume.
LEIFLIKE_DATA_DIR=/data
